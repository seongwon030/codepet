{
  "name": "desktop-pet",
  "version": "0.1.0",
  "private": true,
  "description": "macOS desktop pet that reacts to Claude Code / Codex sessions",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run copy:assets",
    "copy:assets": "mkdir -p dist/renderer && cp src/renderer/index.html dist/renderer/index.html",
    "start": "npm run build && electron .",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "dist": "npm run build && electron-builder --mac dmg"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "ps-list": "^7.2.0"
  }
}
